a = {10,20,30,40}
b = {30,40,50,60}
#mathematical operations

print(a.union(b))# gaertianeba
print(a | b) # shortcut
print(a.intersection(b)) # saerto elementebi
print(a & b)#shortcut
print(a.difference(b))# elementebi romlebic mxolod a shia
print(a - b)#shortcut
print(b - a)#shortcut
print(a.symmetric_difference(b))#gvachvenebs elementebs romlebic ar aris saerto orivestivs
print(a ^ b)

a = {30,40}
b = {30,40,50,60}

print(a.issubset(b))#tu a sheicavs yvela b-s elemenets
print(b.issuperset(a))#tu b sheicavs yvela a-s elemenets

print(a.isdisjoint(b))#roca orives sxva da sxva elementebi aqvs

